{
  "name": "rain-2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test tests/*.test.js",
    "check": "node scripts/check-syntax.mjs",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "check:secrets": "git ls-files -z --cached --others --exclude-standard | node scripts/check-secrets.mjs",
    "test:smoke": "playwright test",
    "ci": "npm run check && npm run typecheck && npm test && npm run build && npm run check:secrets && npm run test:smoke"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "glslify": "^7.1.1",
    "monaco-editor": "^0.43.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  }
}
